# Example environment variables for local ops tooling.
# Copy to .env and fill in. Never commit real secrets.

XIBO_CMS_URL=https://cms.example.local
XIBO_CLIENT_ID=
XIBO_CLIENT_SECRET=
MEDIA_STORE_URI=s3://exhibits/

# --- Ephemeral visual QA (ops/qa) ---
# Prefer ops/qa/config.env for the local Docker stack; these are also read by
# run_qa_pipeline.py when set in the process environment.
# XIBO_ADMIN_USER=xibo_admin
# XIBO_ADMIN_PASSWORD=password
# XIBO_DISPLAY_NAME=qa-kiosk-01
# XIBO_CMS_KEY=
# QA_CAPTURE_WAIT_SECONDS=45
