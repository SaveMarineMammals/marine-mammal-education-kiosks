# Copy to config.env (gitignored) for local deterministic QA runs.
# Never commit real production secrets.

# --- MySQL (must be alphanumeric; Xibo Docker convention) ---
MYSQL_PASSWORD=xiboQaMysqlPass16
MYSQL_ROOT_PASSWORD=xiboQaRootPass16

# --- Host port mappings ---
CMS_HOST_PORT=8080
XMR_HOST_PORT=9505
CMS_SERVER_NAME=localhost

# --- CMS URL as seen by the host orchestrator ---
XIBO_CMS_URL=http://127.0.0.1:8080

# --- CMS URL as seen by containers on the compose network ---
XIBO_CMS_INTERNAL_URL=http://cms-web

# --- Fresh Xibo admin (default on first Docker install) ---
XIBO_ADMIN_USER=xibo_admin
XIBO_ADMIN_PASSWORD=password

# --- OAuth2 application (client credentials). Leave blank to auto-bootstrap. ---
XIBO_CLIENT_ID=
XIBO_CLIENT_SECRET=

# --- Player ---
XIBO_DISPLAY_NAME=qa-kiosk-01
XIBO_CMS_KEY=
XIBO_HARDWARE_KEY=qa-kiosk-01-hw
XIBO_PLAYER_SNAP_CHANNEL=stable

# --- Pipeline ---
QA_EXHIBIT_SLUG=humpback-migration
QA_RECORD_DURATION=30
# Optional override; leave unset to use qa-<exhibit-slug>
# QA_LAYOUT_NAME=qa-humpback-migration
QA_CAPTURE_WAIT_SECONDS=45
QA_COMPOSE_PROJECT=xibo-qa
