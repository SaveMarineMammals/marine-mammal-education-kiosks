# Optional Git LFS for mid-size binaries committed under exhibits or framework.
# Install Git LFS, then: git lfs install
# Only large files (≥ 2 MB) and video belong in the external media store.
# Images and sound under 2 MB each may live in this repo.

# Shell scripts must stay LF so Linux containers can execute shebangs.
*.sh text eol=lf
ops/qa/entrypoint.sh text eol=lf

# Exhibit stills under 2 MB (previews + scene assets)
exhibits/**/media/previews/**/*.jpg filter=lfs diff=lfs merge=lfs -text
exhibits/**/media/previews/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
exhibits/**/media/previews/**/*.png filter=lfs diff=lfs merge=lfs -text
exhibits/**/media/previews/**/*.webp filter=lfs diff=lfs merge=lfs -text
exhibits/**/media/assets/**/*.jpg filter=lfs diff=lfs merge=lfs -text
exhibits/**/media/assets/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
exhibits/**/media/assets/**/*.png filter=lfs diff=lfs merge=lfs -text
exhibits/**/media/assets/**/*.webp filter=lfs diff=lfs merge=lfs -text
exhibits/**/media/assets/**/*.zip filter=lfs diff=lfs merge=lfs -text

# Shared branding binaries (logos/fonts when added as non-text)
framework/branding/**/*.jpg filter=lfs diff=lfs merge=lfs -text
framework/branding/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
framework/branding/**/*.png filter=lfs diff=lfs merge=lfs -text
framework/branding/**/*.webp filter=lfs diff=lfs merge=lfs -text
framework/branding/**/*.ttf filter=lfs diff=lfs merge=lfs -text
framework/branding/**/*.otf filter=lfs diff=lfs merge=lfs -text
framework/branding/**/*.woff filter=lfs diff=lfs merge=lfs -text
framework/branding/**/*.woff2 filter=lfs diff=lfs merge=lfs -text
